<Window x:Class="LoLDraftSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoL Draft Simulator" Height="900" Width="1440"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Background>
        <SolidColorBrush Color="#0B0B0F"/>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="DpmBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1C1C28"/>
            <Setter Property="Foreground"      Value="#C8AA6E"/>
            <Setter Property="BorderBrush"     Value="#2E2E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#272738"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C8AA6E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValidateBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1A3A1A"/>
            <Setter Property="Foreground"      Value="#27AE60"/>
            <Setter Property="BorderBrush"     Value="#27AE60"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="16,9"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#224A22"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4ECB71"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#111811"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1E2E1E"/>
                                <Setter Property="Foreground" Value="#3A5A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="Foreground"  Value="#7A7A9A"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="18,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C8AA6E"/>
                                <Setter Property="Foreground" Value="#C8AA6E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DpmCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1C1C28"/>
            <Setter Property="Foreground"      Value="#E8E8E8"/>
            <Setter Property="BorderBrush"     Value="#2E2E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <!-- Slot vide ban -->
        <Style x:Key="EmptyBan" TargetType="Border">
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="Background"      Value="#0E0E15"/>
            <Setter Property="BorderBrush"     Value="#252535"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Margin"          Value="3,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Tabs -->
            <RowDefinition Height="28"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#0E0E15"
                BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="LOL" Foreground="#C8AA6E" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text=" DRAFT" Foreground="#E8E8E8" FontSize="17" FontWeight="Light"/>
                <TextBlock Text=" SIMULATOR" Foreground="#55556A" FontSize="17" FontWeight="Light"/>
            </StackPanel>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="1" Background="#0B0B0F" BorderThickness="0,1,0,0" BorderBrush="#1E1E2E">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="#0E0E15"/>
                </Style>
            </TabControl.Resources>

            <!-- ===== ONGLET DRAFT ===== -->
            <TabItem Header="DRAFT" Style="{StaticResource TabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68"/>  <!-- Bans -->
                        <RowDefinition Height="*"/>   <!-- Corps -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══ BANS ══ -->
                    <Border Grid.Row="0" Grid.ColumnSpan="3"
                            Background="#0E0E15"
                            BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bans Blue -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="BANS" Foreground="#3B8BEB" FontSize="9"
                                           FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,8,0" LetterSpacing="2"/>
                                <!-- Champions bannis Blue -->
                                <ItemsControl x:Name="BlueBansControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="46" Height="46" Margin="2,0"
                                                    CornerRadius="4" ClipToBounds="True"
                                                    BorderBrush="#3B8BEB" BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding IconPath}" Stretch="UniformToFill" Opacity="0.45"/>
                                                    <Border Background="#99000000"/>
                                                    <TextBlock Text="✕" Foreground="#EB4B4B" FontSize="18"
                                                               FontWeight="Bold" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Slots vides Blue -->
                                <ItemsControl x:Name="EmptyBlueBansControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource EmptyBan}">
                                                <TextBlock Text="?" Foreground="#252535" FontSize="18"
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Centre : phase + bouton valider -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <Border Background="#13131A" BorderBrush="#2E2E42"
                                        BorderThickness="1" CornerRadius="5" Padding="10,5"
                                        Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock x:Name="PhaseLabel" Text="PHASE DE BAN"
                                                   Foreground="#C8AA6E" FontSize="11"
                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                   LetterSpacing="1"/>
                                        <TextBlock x:Name="ActionLabel" Text="1 / 20"
                                                   Foreground="#55556A" FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Slots vides Red (à gauche des bans Red) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <ItemsControl x:Name="EmptyRedBansControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource EmptyBan}">
                                                <TextBlock Text="?" Foreground="#252535" FontSize="18"
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Bans Red -->
                                <ItemsControl x:Name="RedBansControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="46" Height="46" Margin="2,0"
                                                    CornerRadius="4" ClipToBounds="True"
                                                    BorderBrush="#EB4B4B" BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding IconPath}" Stretch="UniformToFill" Opacity="0.45"/>
                                                    <Border Background="#99000000"/>
                                                    <TextBlock Text="✕" Foreground="#EB4B4B" FontSize="18"
                                                               FontWeight="Bold" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="BANS" Foreground="#EB4B4B" FontSize="9"
                                           FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="8,0,0,0" LetterSpacing="2"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══ BLUE PICKS ══ -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Background="#0C0F18" BorderBrush="#1A2840" BorderThickness="0,0,1,0">
                        <StackPanel Margin="8,10">
                            <TextBlock Text="BLUE TEAM" Foreground="#3B8BEB"
                                       FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <!-- Picks Blue -->
                            <ItemsControl x:Name="BluePicksControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="74" Margin="0,3" CornerRadius="5"
                                                Background="#111820" BorderBrush="#1E3050" BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="74"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Image Source="{Binding IconPath}" Stretch="UniformToFill"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8E8"
                                                               FontWeight="SemiBold" FontSize="11"/>
                                                    <TextBlock Text="{Binding PrimaryRole}" Foreground="#3B8BEB"
                                                               FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Slots vides Blue -->
                            <ItemsControl x:Name="EmptyBluePicksControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="74" Margin="0,3" CornerRadius="5"
                                                Background="#09111A" BorderBrush="#111E30" BorderThickness="1">
                                            <TextBlock Text="— vide —" Foreground="#1A2A40"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontStyle="Italic" FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ══ CENTRE ══ -->
                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="48"/>   <!-- Filtres -->
                            <RowDefinition Height="52"/>   <!-- Champion sélectionné + Valider -->
                            <RowDefinition Height="*"/>    <!-- Grille -->
                            <RowDefinition Height="185"/>  <!-- Blind picks -->
                        </Grid.RowDefinitions>

                        <!-- Filtres -->
                        <Border Grid.Row="0" Background="#0E0E15"
                                BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="10,0">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#13131A" BorderBrush="#2E2E42"
                                        BorderThickness="1" CornerRadius="4" Margin="0,0,8,0">
                                    <TextBox x:Name="SearchBox" Background="Transparent"
                                             Foreground="#7A7A9A" CaretBrush="#C8AA6E"
                                             BorderThickness="0" Padding="10,6" FontSize="12"
                                             Text="Rechercher..."
                                             GotFocus="SearchBox_GotFocus"
                                             LostFocus="SearchBox_LostFocus"
                                             TextChanged="SearchBox_TextChanged"/>
                                </Border>
                                <ComboBox x:Name="RoleFilter" Grid.Column="1"
                                          Style="{StaticResource DpmCombo}"
                                          Margin="0,0,8,0"
                                          SelectionChanged="RoleFilter_SelectionChanged">
                                    <ComboBoxItem Content="Tous les rôles" IsSelected="True"/>
                                    <ComboBoxItem Content="Top"/>
                                    <ComboBoxItem Content="Jungle"/>
                                    <ComboBoxItem Content="Mid"/>
                                    <ComboBoxItem Content="Bot"/>
                                    <ComboBoxItem Content="Support"/>
                                </ComboBox>
                                <Button Grid.Column="2" Content="Reset"
                                        Style="{StaticResource DpmBtn}"
                                        Click="ResetDraft_Click"/>
                            </Grid>
                        </Border>

                        <!-- Champion sélectionné + Bouton Valider -->
                        <Border Grid.Row="1" Background="#0E0E15"
                                BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="10,0">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Champion en attente -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="SelectedChampBorder"
                                            Width="38" Height="38" CornerRadius="4"
                                            ClipToBounds="True" Margin="0,0,10,0"
                                            Background="#13131A" BorderBrush="#2E2E42" BorderThickness="1">
                                        <Image x:Name="SelectedChampImage" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="SelectedChampName"
                                                   Text="Aucun champion sélectionné"
                                                   Foreground="#55556A" FontSize="12"/>
                                        <TextBlock x:Name="SelectedChampAction"
                                                   Text="" Foreground="#7A7A9A" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Bouton Valider -->
                                <Button x:Name="ValidateBtn" Grid.Column="1"
                                        Content="✔  VALIDER"
                                        Style="{StaticResource ValidateBtn}"
                                        IsEnabled="False"
                                        Click="ValidateAction_Click"
                                        Width="120" Height="36"/>
                            </Grid>
                        </Border>

                        <!-- Grille champions -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      Background="#0B0B0F">
                            <ItemsControl x:Name="ChampionGrid" Margin="8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="70" Height="78" Margin="3"
                                                ToolTip="{Binding ToolTip}"
                                                Click="Champion_Click"
                                                Tag="{Binding}"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <Border CornerRadius="5" ClipToBounds="True"
                                                    Background="#13131A">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="#1E1E2E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBlindPick}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#27AE60"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#C8AA6E"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Image Source="{Binding IconPath}"
                                                           Width="70" Height="70"
                                                           Stretch="UniformToFill"
                                                           VerticalAlignment="Top"/>
                                                    <!-- Badge blind -->
                                                    <Border HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,3,3,0"
                                                            CornerRadius="3" Padding="2,1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Setter Property="Background" Value="#CC27AE60"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBlindPick}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="🛡" FontSize="9"/>
                                                    </Border>
                                                    <!-- Nom -->
                                                    <Border VerticalAlignment="Bottom"
                                                            Background="#DD0B0B0F" Padding="2,2">
                                                        <TextBlock Text="{Binding Name}" Foreground="#C8C8C8"
                                                                   FontSize="8" TextTrimming="CharacterEllipsis"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- BLIND PICKS / RECOMMANDATIONS -->
                        <Border Grid.Row="3" Background="#0E0E15"
                                BorderBrush="#1E1E2E" BorderThickness="0,1,0,0"
                                Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#1A2A1A" CornerRadius="3" Padding="7,3" Margin="0,0,10,0">
                                        <TextBlock Text="🛡  BLIND PICKS / RECOMMANDATIONS"
                                                   Foreground="#27AE60" FontSize="11" FontWeight="Bold"
                                                   LetterSpacing="1"/>
                                    </Border>
                                    <TextBlock x:Name="BlindPickRoleLabel"
                                               Text="— Tous rôles" Foreground="#7A7A9A"
                                               FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="BlindPicksControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="135" Margin="0,0,8,0"
                                                        Background="#13131A"
                                                        BorderBrush="#27AE60" BorderThickness="1"
                                                        CornerRadius="6" ClipToBounds="True">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Image Source="{Binding Champion.IconPath}"
                                                               Stretch="UniformToFill"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0,4,0">
                                                            <TextBlock Text="{Binding Champion.Name}"
                                                                       Foreground="#E8E8E8" FontWeight="SemiBold"
                                                                       FontSize="10" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding ScoreLabel}"
                                                                       Foreground="#C8AA6E" FontSize="9" Margin="0,2,0,0"/>
                                                            <TextBlock Text="{Binding MasteryLabel}"
                                                                       Foreground="#7A7A9A" FontSize="8" Margin="0,1,0,0"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding CounterLabel}"
                                                                       Foreground="#EB8C3B" FontSize="8" Margin="0,1,0,0"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ══ RED PICKS ══ -->
                    <Border Grid.Row="1" Grid.Column="2"
                            Background="#180E0E" BorderBrush="#2E1A1A" BorderThickness="1,0,0,0">
                        <StackPanel Margin="8,10">
                            <TextBlock Text="RED TEAM" Foreground="#EB4B4B"
                                       FontSize="9" FontWeight="Bold" LetterSpacing="2"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="RedPicksControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="88" Margin="0,3" CornerRadius="5"
                                                Background="#180E0E" BorderBrush="#2E1A1A" BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="74"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="4,0,6,0">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8E8"
                                                               FontWeight="SemiBold" FontSize="11"
                                                               HorizontalAlignment="Right"/>
                                                    <Border HorizontalAlignment="Right" CornerRadius="3"
                                                            Padding="5,2" Margin="0,4,0,0" Background="#1C1C28">
                                                        <TextBlock Text="{Binding RolesLabel}"
                                                                   Foreground="{Binding RoleColor}"
                                                                   FontSize="9" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding RolesEmoji}" FontSize="12"
                                                               HorizontalAlignment="Right" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Image Grid.Column="1" Source="{Binding IconPath}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl x:Name="EmptyRedPicksControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="88" Margin="0,3" CornerRadius="5"
                                                Background="#110808" BorderBrush="#1E1010" BorderThickness="1">
                                            <TextBlock Text="— vide —" Foreground="#2E1212"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontStyle="Italic" FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== CHAMPION POOL ===== -->
            <TabItem Header="CHAMPION POOL" Style="{StaticResource TabStyle}">
                <Grid Background="#0B0B0F" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#13131A" BorderBrush="#1E1E2E"
                            BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="AJOUTER UN CHAMPION" Foreground="#C8AA6E"
                                       FontSize="10" FontWeight="Bold" LetterSpacing="2" Margin="0,0,0,16"/>
                            <TextBlock Text="Champion" Foreground="#7A7A9A" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="PoolChampionPicker" Style="{StaticResource DpmCombo}"
                                      Margin="0,0,0,12" Height="32" DisplayMemberPath="Name"/>
                            <TextBlock Text="Rôle" Foreground="#7A7A9A" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="PoolRolePicker" Style="{StaticResource DpmCombo}"
                                      Margin="0,0,0,12" Height="32">
                                <ComboBoxItem Content="Top"/>
                                <ComboBoxItem Content="Jungle"/>
                                <ComboBoxItem Content="Mid"/>
                                <ComboBoxItem Content="Bot"/>
                                <ComboBoxItem Content="Support"/>
                            </ComboBox>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Maîtrise" Foreground="#7A7A9A" FontSize="11"/>
                                <TextBlock x:Name="MasteryDescLabel" Grid.Column="1"
                                           Text="Compétent" Foreground="#C8AA6E" FontSize="11" FontStyle="Italic"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="MasterySlider" Minimum="1" Maximum="10" Value="5"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        VerticalAlignment="Center"
                                        ValueChanged="MasterySlider_ValueChanged"/>
                                <TextBlock x:Name="MasteryValueLabel" Grid.Column="1"
                                           Text="5" Foreground="#F0D070" FontSize="20"
                                           FontWeight="Bold" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <CheckBox x:Name="MainPickCheck" Content="Main pick sur ce rôle"
                                      Foreground="#E8E8E8" Margin="0,0,0,16"/>
                            <Button Content="+ Ajouter" Style="{StaticResource DpmBtn}"
                                    Height="34" Click="AddToPool_Click"/>
                            <Separator Background="#1E1E2E" Margin="0,16"/>
                            <TextBlock Text="STATS DU POOL" Foreground="#7A7A9A"
                                       FontSize="9" FontWeight="Bold" LetterSpacing="2" Margin="0,0,0,8"/>
                            <TextBlock x:Name="PoolStatsLabel" Foreground="#7A7A9A"
                                       FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                            <Button Content="💾  Sauvegarder" Style="{StaticResource DpmBtn}"
                                    Height="32" Margin="0,16,0,0" Click="SavePool_Click"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#13131A" BorderBrush="#1E1E2E"
                                BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MON CHAMPION POOL" Foreground="#C8AA6E"
                                           FontSize="11" FontWeight="Bold" LetterSpacing="1"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="PoolRoleFilter"
                                          Style="{StaticResource DpmCombo}" Width="130"
                                          SelectionChanged="PoolRoleFilter_Changed">
                                    <ComboBoxItem Content="Tous les rôles" IsSelected="True"/>
                                    <ComboBoxItem Content="Top"/>
                                    <ComboBoxItem Content="Jungle"/>
                                    <ComboBoxItem Content="Mid"/>
                                    <ComboBoxItem Content="Bot"/>
                                    <ComboBoxItem Content="Support"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ChampionPoolList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="170" Margin="5" Background="#13131A"
                                                BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="68"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border CornerRadius="7,7,0,0" ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding IconPath}" Stretch="UniformToFill" Opacity="0.6"/>
                                                        <Border Background="#CC0B0B0F" VerticalAlignment="Bottom" Padding="8,4">
                                                            <Grid>
                                                                <TextBlock Text="{Binding ChampionName}" Foreground="White"
                                                                           FontWeight="SemiBold" FontSize="12"/>
                                                                <TextBlock Text="{Binding Role}" Foreground="#C8AA6E"
                                                                           FontSize="10" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,8">
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Value="{Binding Mastery}" Minimum="1" Maximum="10"
                                                                     Height="6" Foreground="#C8AA6E" Background="#1E1E2E"
                                                                     VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Mastery}"
                                                                   Foreground="#F0D070" FontWeight="Bold"
                                                                   FontSize="13" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding MasteryLabel}" Foreground="#7A7A9A"
                                                               FontSize="10" HorizontalAlignment="Center"/>
                                                    <Button Content="Retirer" Tag="{Binding}"
                                                            Click="RemoveFromPool_Click"
                                                            Margin="0,6,0,0" Height="22" FontSize="10"
                                                            Foreground="#EB4B4B" Background="Transparent"
                                                            BorderBrush="#2E1A1A" BorderThickness="1" Cursor="Hand"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ===== PARAMÈTRES ===== -->
            <TabItem Header="PARAMÈTRES" Style="{StaticResource TabStyle}">
                <StackPanel Background="#0B0B0F" Margin="24">
                    <TextBlock Text="PARAMÈTRES" Foreground="#C8AA6E"
                               FontSize="11" FontWeight="Bold" LetterSpacing="2" Margin="0,0,0,20"/>
                    <TextBlock Text="Côté par défaut" Foreground="#7A7A9A" FontSize="12" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton x:Name="BlueSideRadio" Content="Blue Side" IsChecked="True"
                                     Foreground="#3B8BEB" FontWeight="SemiBold" Margin="0,0,20,0"/>
                        <RadioButton x:Name="RedSideRadio" Content="Red Side"
                                     Foreground="#EB4B4B" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="Nombre de recommandations" Foreground="#7A7A9A" FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox x:Name="RecoCountCombo" Style="{StaticResource DpmCombo}"
                              Width="100" HorizontalAlignment="Left">
                        <ComboBoxItem Content="3" IsSelected="True"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="8"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="#0E0E15" BorderBrush="#1E1E2E" BorderThickness="0,1,0,0" Padding="12,4">
            <TextBlock x:Name="StatusBar" Foreground="#55556A" FontSize="11"
                       Text="Prêt — Clique sur un champion pour le sélectionner, puis VALIDER."/>
        </Border>
    </Grid>
</Window>
